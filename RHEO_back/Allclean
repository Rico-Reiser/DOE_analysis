#!/bin/bash

echo ">>> Starting batch clean for DOE cases..."

# alle Unterordner (Run-Cases) im aktuellen Ordner durchlaufen
for caseDir in */; do

    # sicherstellen, dass es wirklich ein Case ist (z. B. enthält 0_orig)
    if [ -d "$caseDir/0_orig" ]; then

        echo ""
        echo "=============================="
        echo ">>> Processing case: $caseDir"
        echo "=============================="

        cd "$caseDir" || continue

        echo ">>> Cleaning case directory..."

        # Zeitordner löschen
        for d in [0-9]*; do
            if [ -d "$d" ] && [ "$d" != "0_orig" ]; then
                echo ">>> Removing directory: $d"
                rm -rf "$d"
            fi
        done

        # Mesh löschen
        rm -rf constant/polyMesh

        # Parallel
        rm -rf processor*

        # PostProcessing
        rm -rf postProcessing

        # Logs
        rm -f log.*

        # Feature edges
        rm -rf constant/extendedFeatureEdgeMesh

        # 0 neu setzen
        echo ">>> Restoring 0 from 0_orig"
        rm -rf 0
        cp -r 0_orig 0

        cd ..
    fi

done

echo ""
echo ">>> All DOE cases cleaned successfully."