water
{
    transportModel  Newtonian;

    rho             1100;
    nu              1.81e-5;
}

// Air
air
{
    transportModel  Newtonian;
    nu              1.5e-5;
    rho             1.2;
}

contactFluid
{
    transportModel  Newtonian;

    rho             1597.1;

    
    nu              2.26e-05;
}




